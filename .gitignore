# =============================================================================
#  Viva AI — training pipeline .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
#  Python environments / caches
# -----------------------------------------------------------------------------
.venv/
venv/
env/
.python-version
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
nosetests.xml

# -----------------------------------------------------------------------------
#  Secrets / config
# -----------------------------------------------------------------------------
# .env may contain secrets in some setups — ignore by default and use
# .env.example as the committed reference.
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# -----------------------------------------------------------------------------
#  Generated data (regenerated by `scripts/generate_data.py`)
# -----------------------------------------------------------------------------
data/raw/
data/synthetic/
data/processed/
data/splits/
*.parquet
*.npz
*.npy

# -----------------------------------------------------------------------------
#  Training artefacts
# -----------------------------------------------------------------------------
# Keep models/final/ (final TFLite + metadata) committed as the deliverable.
# Keep evaluation_artifacts/ (model card, metrics, plots) for reviewers.
# Everything else is regenerated by training and should NOT be committed.
models/checkpoints/
models/evaluation/
*.h5
*.keras
*.ckpt
logs/
runs/
mlruns/
wandb/
tensorboard/

# -----------------------------------------------------------------------------
#  Notebook scratch
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_meta

# -----------------------------------------------------------------------------
#  Editor / OS
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
#  Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
.cache/
